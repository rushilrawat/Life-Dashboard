# Server-side only. Used by the backend proxy's per-service adapters
# (server/adapters/) so credentials never reach the browser bundle.
# Copy to .env and fill in; .env is gitignored.

# Free personal access token from github.com/settings/tokens — no special
# scopes needed to read a public profile's contribution data.
GITHUB_TOKEN=

# Google Calendar: create an OAuth client (console.cloud.google.com ->
# APIs & Services -> Credentials -> Create OAuth client ID -> Web
# application), add http://localhost:3001/api/auth/google/callback as an
# authorized redirect URI, then paste its client ID/secret below. No
# refresh token to paste in — GOOGLE_REFRESH_TOKEN is written here
# automatically once you click "Connect with Google" in Settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
